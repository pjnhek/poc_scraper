# NVIDIA Build API key. Free preview models live at https://build.nvidia.com/
# The endpoint is OpenAI-compatible: https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# Exa API key for neural search of company news + about pages (https://exa.ai/)
EXA_API_KEY=

# Browserbase credentials for headless rendering fallback (https://browserbase.com/)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Google service account JSON path. Service account must have edit access to
# the destination spreadsheet, OR Sheets API enabled to create new sheets.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Optional: existing spreadsheet ID to append rows to. If unset, a new sheet
# is created per run and the URL is printed at the end.
GOOGLE_SHEET_ID=

# Writer model: drafts firmographics, ICP score JSON, personas, outreach hooks.
# Hot params for creative writing.
WRITER_MODEL=minimaxai/minimax-m2.7
WRITER_TEMPERATURE=1.0
WRITER_TOP_P=0.95
WRITER_MAX_TOKENS=8192

# Judge model: scores outreach paragraphs against the rubric. MUST be a
# different family from the writer to avoid self-grading bias. Defaults
# to Seed-OSS 36B (a reasoning model). Cold temperature for consistency
# per NeMo guidance, with reasoning budget unlimited.
JUDGE_MODEL=bytedance/seed-oss-36b-instruct
JUDGE_TEMPERATURE=0.3
JUDGE_TOP_P=0.95
JUDGE_MAX_TOKENS=4096
# Bounded reasoning budget so the JSON fits in max_tokens.
# -1 = unlimited (only safe with a much larger JUDGE_MAX_TOKENS).
# 0 = disabled (skip reasoning entirely). Positive int = cap.
JUDGE_REASONING_BUDGET=1024

# Concurrency cap for the per-account pipeline.
PIPELINE_CONCURRENCY=5

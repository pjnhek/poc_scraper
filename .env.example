# --- LLM provider ---
# DeepSeek is the recommended provider; ~$0.20-0.40 per 10-domain run on
# v4-flash + v4-pro (with thinking + reasoning_effort=high on the judge).
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Alternative free-tier provider. Used when DEEPSEEK_API_KEY is empty.
# Free preview models live at https://build.nvidia.com/
NVIDIA_API_KEY=

# Force a specific provider regardless of which keys are set.
# Options: "deepseek" | "nvidia". Leave empty for auto-select (deepseek
# wins if its key is present, otherwise falls back to nvidia).
# LLM_PROVIDER=

# --- Other services ---
# Exa API key for neural search of company news + about pages (https://exa.ai/)
EXA_API_KEY=

# Browserbase credentials for headless rendering fallback (https://browserbase.com/)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Google service account JSON path. Service account must have edit access to
# the destination spreadsheet, OR Sheets API enabled to create new sheets.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Optional: existing spreadsheet ID to append rows to. If unset, a new sheet
# is created per run and the URL is printed at the end.
GOOGLE_SHEET_ID=

# --- Writer (drafts firmographics, ICP score, personas, outreach hooks) ---
# Hot params for creative writing. The writer has thinking mode OFF for speed.
# Defaults are picked per provider; uncomment to override.
# WRITER_MODEL_DEEPSEEK=deepseek-v4-flash
# WRITER_MODEL_NVIDIA=minimaxai/minimax-m2.7
WRITER_TEMPERATURE=1.0
WRITER_TOP_P=0.95
WRITER_MAX_TOKENS=8192

# --- Judge (scores outreach against the rubric, decomposes claims) ---
# Cold temperature for consistency per NeMo guidance. On DeepSeek the
# default judge is the same v4-flash model as the writer but with
# thinking mode enabled and reasoning_effort=medium - keeps each call
# at ~5-10s, fast enough for a live demo. Switch to deepseek-v4-pro
# with reasoning_effort=high for offline analysis runs (~30-60s/call,
# more rigorous claim decomposition).
# JUDGE_MODEL_DEEPSEEK=deepseek-v4-flash
# JUDGE_MODEL_NVIDIA=bytedance/seed-oss-36b-instruct

# Cross-family calibration judge override (EVAL-04 / make eval-calibration).
# The collusion-signal calibration needs a second judge from a DIFFERENT
# model family than DeepSeek; the specific provider is not load-bearing.
# Leave all three blank to use the NVIDIA judge (default). Set all three
# to point the cross-family judge at any OpenAI-compatible endpoint when
# the free NVIDIA tier is too unreliable for a full batch. Half-set
# (one or two of three) fails fast at config time.
# CALIBRATION_JUDGE_API_KEY=
# CALIBRATION_JUDGE_BASE_URL=
# CALIBRATION_JUDGE_MODEL=

# Current reasoning models are tuned for temperature 1.0; do not lower it
# (the reasoning trace supplies judge consistency, not a cold sampler).
# JUDGE_MAX_TOKENS must cover the reasoning trace plus the JSON answer or
# a thinking judge truncates mid-answer into a parse failure.
JUDGE_TEMPERATURE=1.0
JUDGE_TOP_P=0.95
JUDGE_MAX_TOKENS=32768

# DeepSeek reasoning effort for the judge: "low" | "medium" | "high".
# Combined with thinking mode (auto-enabled on the judge).
JUDGE_REASONING_EFFORT_DEEPSEEK=medium

# NVIDIA-only: reasoning budget for thinking-budget-aware models.
# 0 = disabled (recommended on free tier), positive = bounded, -1 = unlimited.
JUDGE_REASONING_BUDGET=0

# --- Run controls ---
# Concurrency cap for the per-account pipeline.
PIPELINE_CONCURRENCY=5
# Per-LLM-client cap on simultaneous in-flight requests. DeepSeek tolerates
# higher parallelism (6 is sane); drop to 2-3 for NVIDIA free tier if 429s appear.
LLM_MAX_IN_FLIGHT=6

# Optional cap on how many domains `make run` processes from accounts.csv.
# Useful for demos or to avoid rate limits. Unset = process all.
# RUN_LIMIT=5
